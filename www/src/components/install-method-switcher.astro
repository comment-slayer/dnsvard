---
const methods = [
  {
    key: 'curl',
    label: 'curl',
    command: 'curl -fsSL https://dnsvard.com/install | sh',
    caption: 'macOS and Linux installer script.',
    help: 'Upgrade path: dnsvard upgrade',
  },
  {
    key: 'brew',
    label: 'homebrew',
    command: 'brew install --cask comment-slayer/tap/dnsvard',
    caption: 'Homebrew cask for macOS.',
    help: 'Upgrade path: brew upgrade --cask comment-slayer/tap/dnsvard',
  },
] as const;
---

<div class="mt-3 grid gap-2.5 md:mt-4 md:gap-3">
  {
    methods.map((method) => (
      <section
        class="min-w-0 rounded-[0.85rem] border border-slate-700 bg-slate-900/70 p-3.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] transition-colors hover:border-slate-500 md:p-4"
        aria-label={`${method.label} install command`}
      >
        <p class="mb-2 min-h-[1.2rem] text-[0.82rem] text-slate-400 md:mb-[0.62rem] md:text-[0.84rem]">{method.caption}</p>
        <button
          type="button"
          class="group relative block w-full max-w-full min-w-0 touch-manipulation select-text rounded-[0.65rem] border border-slate-700 bg-slate-950 px-[0.85rem] py-[0.8rem] pr-13 text-left text-inherit transition-colors [font:inherit] hover:border-slate-500 hover:bg-slate-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400/60 disabled:cursor-default max-[640px]:pr-12 md:py-[0.85rem]"
          data-copy-button
          data-copy-command={method.command}
          data-copy-install-method={method.key}
          aria-label={`Copy ${method.label} install command`}
        >
          <pre class="m-0 max-w-full overflow-x-auto text-[0.79rem] [-webkit-overflow-scrolling:touch] md:text-[0.9rem]"><code class="whitespace-nowrap"><span class="mr-[0.3rem] text-slate-500">$</span>{method.command}</code></pre>
          <span
            class="pointer-events-none absolute right-2 top-1/2 grid h-8 w-8 -translate-y-1/2 place-items-center rounded-[0.55rem] border border-slate-700 bg-slate-900 text-slate-300"
            data-copy-status
            aria-hidden="true"
          >
            <span class="grid" data-copy-icon>⧉</span>
            <span class="hidden" data-check-icon>✓</span>
          </span>
          <span class="sr-only" data-copy-live aria-live="polite"></span>
        </button>
        <p class="mt-2 text-[0.77rem] text-slate-400 md:mt-[0.7rem] md:text-[0.78rem]">{method.help}</p>
      </section>
    ))
  }
</div>

<script is:inline>
  (() => {
    const buttons = Array.from(document.querySelectorAll('[data-copy-button]'));
    const pressPoints = new WeakMap();
    const COPY_TIMEOUT_MS = 3000;
    const DRAG_THRESHOLD = 4;
    let activeButton = null;
    let activeTimer = null;

    const getCopyElements = (button) => {
      const status = button.querySelector('[data-copy-status]');
      const copyIcon = button.querySelector('[data-copy-icon]');
      const checkIcon = button.querySelector('[data-check-icon]');
      const live = button.querySelector('[data-copy-live]');

      if (
        !(status instanceof HTMLElement) ||
        !(copyIcon instanceof HTMLElement) ||
        !(checkIcon instanceof HTMLElement) ||
        !(live instanceof HTMLElement)
      ) {
        return null;
      }

      return { status, copyIcon, checkIcon, live };
    };

    const hasSelectedTextInside = (target) => {
      const selection = window.getSelection();
      if (
        !selection ||
        selection.isCollapsed ||
        selection.toString().trim() === ''
      ) {
        return false;
      }

      return (
        (!!selection.anchorNode && target.contains(selection.anchorNode)) ||
        (!!selection.focusNode && target.contains(selection.focusNode))
      );
    };

    const setCopiedState = (button, copied) => {
      const els = getCopyElements(button);
      if (els === null) {
        return;
      }

      const { status, copyIcon, checkIcon, live } = els;

      button.disabled = copied;
      status.classList.toggle('text-emerald-300', copied);
      status.classList.toggle('text-slate-300', !copied);
      copyIcon.classList.toggle('hidden', copied);
      copyIcon.classList.toggle('grid', !copied);
      checkIcon.classList.toggle('hidden', !copied);
      checkIcon.classList.toggle('grid', copied);
      live.textContent = copied ? 'Install command copied' : '';
    };

    const copyText = async (text) => {
      if (
        navigator.clipboard &&
        typeof navigator.clipboard.writeText === 'function' &&
        window.isSecureContext
      ) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const area = document.createElement('textarea');
      area.value = text;
      area.setAttribute('readonly', '');
      area.style.position = 'fixed';
      area.style.top = '-9999px';
      area.style.left = '-9999px';
      document.body.appendChild(area);
      area.select();
      const copied = document.execCommand('copy');
      document.body.removeChild(area);
      return copied;
    };

    buttons.forEach((node) => {
      if (!(node instanceof HTMLButtonElement)) {
        return;
      }

      node.addEventListener('pointerdown', (event) => {
        pressPoints.set(node, { x: event.clientX, y: event.clientY });
      });

      node.addEventListener('click', async (event) => {
        const target = event.currentTarget;
        if (!(target instanceof HTMLButtonElement)) {
          return;
        }

        const press = pressPoints.get(target);
        pressPoints.delete(target);

        if (target.disabled || hasSelectedTextInside(target)) {
          return;
        }

        if (
          press &&
          Math.hypot(event.clientX - press.x, event.clientY - press.y) >
            DRAG_THRESHOLD
        ) {
          return;
        }

        const command = target.dataset.copyCommand;
        if (!command) {
          return;
        }

        const installMethod = target.dataset.copyInstallMethod;
        const capture = window.dnsvardCapture;
        if (installMethod && typeof capture === 'function') {
          capture('copy-install', { property: installMethod });
        }

        const copied = await copyText(command).catch(() => false);
        if (!copied) {
          return;
        }

        if (activeTimer !== null) {
          window.clearTimeout(activeTimer);
          activeTimer = null;
        }

        if (activeButton instanceof HTMLButtonElement) {
          setCopiedState(activeButton, false);
        }

        setCopiedState(target, true);
        activeButton = target;
        activeTimer = window.setTimeout(() => {
          setCopiedState(target, false);
          activeButton = null;
          activeTimer = null;
        }, COPY_TIMEOUT_MS);
      });
    });
  })();
</script>
